---
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { url } from "@/utils/url-utils";
---

<MainGridLayout
  title="火柴人小游戏"
  description="火柴人 2D 跑酷小游戏"
>
  <div id="stickman-game-shell" class="stickman-game-shell">
    <section class="stickman-game-panel" aria-label="火柴人小游戏">
      <div class="stickman-game-toolbar">
        <div>
          <p class="stickman-kicker">Stickman Runner</p>
          <h2>火柴人 2D 跑酷</h2>
        </div>
        <button id="stickman-fullscreen-button" type="button">
          全屏
        </button>
      </div>
      <iframe
        id="stickman-game-frame"
        title="火柴人 2D 跑酷"
        src={url("/game-assets/stickman/index.html")}
        tabindex="0"
        loading="eager"
        allow="autoplay; fullscreen"
        allowfullscreen
      />
    </section>

    <aside class="stickman-leaderboard" aria-label="火柴人排行榜">
      <div class="stickman-leaderboard-header">
        <div>
          <p class="stickman-kicker">Leaderboard</p>
          <h2>排行榜</h2>
        </div>
        <span>Top 10</span>
      </div>

      <label class="stickman-player-name">
        昵称
        <input id="stickman-player-name" maxlength="16" placeholder="路过的玩家" />
      </label>

      <ol id="stickman-leaderboard-list" class="stickman-leaderboard-list">
        <li class="stickman-leaderboard-empty">排行榜加载中...</li>
      </ol>

      <p id="stickman-leaderboard-status" class="stickman-leaderboard-status"></p>
    </aside>
  </div>
</MainGridLayout>

<script>
  const frame = document.getElementById("stickman-game-frame") as HTMLIFrameElement | null;
  const shell = document.getElementById("stickman-game-shell");
  const fullscreenButton = document.getElementById("stickman-fullscreen-button");
  const playerNameInput = document.getElementById("stickman-player-name") as HTMLInputElement | null;
  const leaderboardList = document.getElementById("stickman-leaderboard-list");
  const leaderboardStatus = document.getElementById("stickman-leaderboard-status");
  const leaderboardApi = "/api/stickman-leaderboard";
  const leaderboardNameKey = "stickman_runner_player_name_v1";
  const gameKeys = new Set(["ArrowUp", "ArrowDown", "ArrowLeft", "ArrowRight", "Space", "KeyW", "KeyS"]);

  document.documentElement.classList.add("stickman-layout");
  document.body.classList.add("stickman-layout");

  function sanitizePlayerName(name: string | null | undefined) {
    const cleaned = String(name || "")
      .replace(/[<>]/g, "")
      .replace(/\s+/g, " ")
      .trim()
      .slice(0, 16);
    return cleaned || "路过的玩家";
  }

  function setLeaderboardStatus(text: string) {
    if (leaderboardStatus) {
      leaderboardStatus.textContent = text;
    }
  }

  function renderLeaderboard(entries: Array<{ name?: string; score?: number }>) {
    if (!leaderboardList) {
      return;
    }
    const topEntries = entries.slice(0, 10);
    if (topEntries.length === 0) {
      leaderboardList.innerHTML = '<li class="stickman-leaderboard-empty">还没有分数，来拿第一个第一名。</li>';
      return;
    }
    leaderboardList.innerHTML = topEntries
      .map((entry, index) => {
        const name = sanitizePlayerName(entry.name);
        const score = Number(entry.score || 0).toLocaleString();
        const rankClass = index < 3 ? ` rank-${index + 1}` : "";
        return `
          <li>
            <span class="stickman-rank${rankClass}">${index + 1}</span>
            <span class="stickman-player">${name}</span>
            <span class="stickman-score">${score}</span>
          </li>
        `;
      })
      .join("");
  }

  async function loadLeaderboard() {
    try {
      const response = await fetch(leaderboardApi, { headers: { accept: "application/json" } });
      if (!response.ok) {
        throw new Error(`HTTP ${response.status}`);
      }
      const data = await response.json();
      renderLeaderboard(data.entries || []);
      setLeaderboardStatus("");
    } catch (_error) {
      renderLeaderboard([]);
      setLeaderboardStatus("排行榜服务暂不可用，分数仍会保存在本机。");
    }
  }

  function setGamePageScrollLock(locked: boolean) {
    document.documentElement.classList.toggle("stickman-page-lock", locked);
    document.body.classList.toggle("stickman-page-lock", locked);
  }

  function setFullscreenUi(active: boolean) {
    shell?.classList.toggle("is-game-fullscreen", active);
    if (fullscreenButton) {
      fullscreenButton.textContent = active ? "退出全屏" : "全屏";
    }
    frame?.contentWindow?.postMessage(
      { type: "stickman:parent-fullscreen", active },
      window.location.origin
    );
  }

  async function setFullscreenOrientation(active: boolean) {
    const orientation = screen.orientation as ScreenOrientation & {
      lock?: (orientation: "landscape") => Promise<void>;
      unlock?: () => void;
    };
    try {
      if (active) {
        await orientation.lock?.("landscape");
        return;
      }
      orientation.unlock?.();
    } catch (_error) {
      // Some browsers do not allow orientation locking; CSS rotation still applies.
    }
  }

  frame?.addEventListener("load", () => {
    frame.focus();
    frame.contentWindow?.focus();
  });

  if (playerNameInput) {
    playerNameInput.value = sanitizePlayerName(localStorage.getItem(leaderboardNameKey));
    playerNameInput.addEventListener("input", () => {
      localStorage.setItem(leaderboardNameKey, sanitizePlayerName(playerNameInput.value));
    });
  }

  fullscreenButton?.addEventListener("click", async () => {
    if (!shell) {
      return;
    }
    try {
      if (document.fullscreenElement) {
        await document.exitFullscreen();
        await setFullscreenOrientation(false);
        setFullscreenUi(false);
        return;
      }
      await shell.requestFullscreen();
      await setFullscreenOrientation(true);
      setFullscreenUi(true);
      frame?.focus();
      frame?.contentWindow?.focus();
    } catch (error) {
      console.warn("进入全屏失败:", error);
    }
  });

  document.addEventListener("fullscreenchange", () => {
    const active = document.fullscreenElement === shell;
    if (!active) {
      void setFullscreenOrientation(false);
    }
    setFullscreenUi(active);
  });

  document.addEventListener("keydown", (event) => {
    if (!document.documentElement.classList.contains("stickman-page-lock")) {
      return;
    }
    if (!gameKeys.has(event.code)) {
      return;
    }
    event.preventDefault();
    frame?.contentWindow?.focus();
  }, { passive: false });

  window.addEventListener("message", (event) => {
    if (event.origin !== window.location.origin) {
      return;
    }
    if (event.data?.type === "stickman:start") {
      setGamePageScrollLock(true);
      frame?.focus();
      frame?.contentWindow?.focus();
      return;
    }
    if (event.data?.type === "stickman:game-over") {
      setGamePageScrollLock(false);
      window.setTimeout(loadLeaderboard, 600);
      return;
    }
    if (event.data?.type === "stickman:leaderboard") {
      renderLeaderboard(event.data.entries || []);
    }
  });

  document.addEventListener("swup:visit:start", () => {
    setGamePageScrollLock(false);
    document.documentElement.classList.remove("stickman-layout");
    document.body.classList.remove("stickman-layout");
  }, { once: true });

  window.addEventListener("pagehide", () => {
    setGamePageScrollLock(false);
    document.documentElement.classList.remove("stickman-layout");
    document.body.classList.remove("stickman-layout");
  });

  loadLeaderboard();
</script>

<style is:global>
  html.stickman-page-lock,
  body.stickman-page-lock {
    overflow: hidden;
  }

  html.stickman-layout #main-grid {
    grid-template-columns: minmax(0, 1fr) !important;
  }

  #main-grid:has(#stickman-game-shell) {
    grid-template-columns: minmax(0, 1fr) !important;
  }

  html.stickman-layout #left-sidebar-wrapper,
  html.stickman-layout #left-sidebar-dynamic,
  html.stickman-layout #right-sidebar-static,
  html.stickman-layout #right-sidebar-dynamic,
  html.stickman-layout #mobile-bottom-sidebar {
    display: none !important;
  }

  #main-grid:has(#stickman-game-shell) #left-sidebar-wrapper,
  #main-grid:has(#stickman-game-shell) #left-sidebar-dynamic,
  #main-grid:has(#stickman-game-shell) #right-sidebar-static,
  #main-grid:has(#stickman-game-shell) #right-sidebar-dynamic,
  #main-grid:has(#stickman-game-shell) #mobile-bottom-sidebar {
    display: none !important;
  }

  html.stickman-layout #category-bar-wrapper {
    display: none !important;
  }

  #main-grid:has(#stickman-game-shell) #category-bar-wrapper {
    display: none !important;
  }

  html.stickman-layout #swup-container,
  html.stickman-layout #content-wrapper {
    overflow: visible;
  }

  #main-grid:has(#stickman-game-shell) #swup-container,
  #main-grid:has(#stickman-game-shell) #content-wrapper {
    overflow: visible;
  }

  .stickman-game-shell {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 360px);
    gap: 18px;
    width: min(1500px, calc(100vw - 32px));
    max-width: 1440px;
    margin-left: 50%;
    transform: translateX(-50%);
  }

  .stickman-game-panel,
  .stickman-leaderboard {
    border: 1px solid rgba(15, 23, 42, 0.12);
    border-radius: 18px;
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.92), rgba(245, 248, 252, 0.86)),
      radial-gradient(circle at 10% 0%, rgba(59, 130, 246, 0.12), transparent 34%);
    box-shadow: 0 18px 50px rgba(15, 23, 42, 0.14);
    backdrop-filter: blur(12px);
  }

  .stickman-game-panel {
    min-width: 0;
    overflow: hidden;
    padding: 14px;
  }

  .stickman-game-toolbar,
  .stickman-leaderboard-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 12px;
  }

  .stickman-kicker {
    margin: 0 0 4px;
    color: var(--primary);
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .stickman-game-toolbar h2,
  .stickman-leaderboard-header h2 {
    margin: 0;
    color: var(--deep-text);
    font-size: 24px;
    font-weight: 800;
    letter-spacing: 0;
  }

  #stickman-fullscreen-button {
    min-width: 84px;
    border: 0;
    border-radius: 10px;
    padding: 10px 16px;
    background: var(--primary);
    color: white;
    font-size: 14px;
    font-weight: 700;
    cursor: pointer;
    box-shadow: 0 10px 24px rgba(37, 99, 235, 0.24);
  }

  #stickman-fullscreen-button:hover {
    filter: brightness(1.05);
  }

  #stickman-game-frame {
    display: block;
    width: 100%;
    height: clamp(680px, calc(100vh - 10rem), 860px);
    border: 0;
    border-radius: 14px;
    background: #eef3f8;
  }

  .stickman-leaderboard {
    align-self: start;
    position: sticky;
    top: 88px;
    padding: 18px;
  }

  .stickman-leaderboard-header span {
    flex: 0 0 auto;
    border-radius: 999px;
    padding: 6px 10px;
    background: rgba(37, 99, 235, 0.12);
    color: var(--primary);
    font-size: 12px;
    font-weight: 800;
  }

  .stickman-player-name {
    display: grid;
    gap: 8px;
    margin-bottom: 16px;
    color: var(--text-90);
    font-size: 13px;
    font-weight: 700;
  }

  .stickman-player-name input {
    width: 100%;
    height: 42px;
    border: 1px solid rgba(15, 23, 42, 0.14);
    border-radius: 12px;
    padding: 0 12px;
    background: rgba(255, 255, 255, 0.82);
    color: var(--deep-text);
    outline: none;
  }

  .stickman-player-name input:focus {
    border-color: var(--primary);
    box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.14);
  }

  .stickman-leaderboard-list {
    display: grid;
    gap: 10px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .stickman-leaderboard-list li {
    display: grid;
    grid-template-columns: 34px minmax(0, 1fr) auto;
    align-items: center;
    gap: 10px;
    min-height: 48px;
    border: 1px solid rgba(15, 23, 42, 0.08);
    border-radius: 14px;
    padding: 8px 10px;
    background: rgba(255, 255, 255, 0.68);
  }

  .stickman-rank {
    width: 30px;
    height: 30px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    background: #e2e8f0;
    color: #334155;
    font-size: 13px;
    font-weight: 900;
  }

  .stickman-rank.rank-1 {
    background: linear-gradient(135deg, #fde68a, #f59e0b);
    color: #422006;
  }

  .stickman-rank.rank-2 {
    background: linear-gradient(135deg, #f8fafc, #94a3b8);
    color: #0f172a;
  }

  .stickman-rank.rank-3 {
    background: linear-gradient(135deg, #fdba74, #c2410c);
    color: #431407;
  }

  .stickman-player {
    min-width: 0;
    overflow: hidden;
    color: var(--deep-text);
    font-weight: 750;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .stickman-score {
    color: var(--primary);
    font-weight: 900;
  }

  .stickman-leaderboard-empty,
  .stickman-leaderboard-status {
    color: var(--text-50);
  }

  .stickman-leaderboard-status {
    min-height: 20px;
    margin: 12px 0 0;
    font-size: 13px;
    line-height: 1.5;
  }

  @media (max-width: 1180px) {
    .stickman-game-shell {
      grid-template-columns: 1fr;
      width: min(100%, calc(100vw - 20px));
      margin-left: auto;
      margin-right: auto;
      transform: none;
    }

    .stickman-leaderboard {
      position: static;
    }
  }

  #stickman-game-shell:fullscreen {
    display: block;
    width: 100vw;
    height: 100vh;
    margin-left: 0;
    padding: 0;
    transform: none;
    overflow: hidden;
    background: #020617;
  }

  #stickman-game-shell:fullscreen .stickman-game-panel {
    position: relative;
    width: 100vw;
    height: 100vh;
    border: 0;
    border-radius: 0;
    padding: 0;
    overflow: hidden;
    background: #020617;
    box-shadow: none;
    backdrop-filter: none;
  }

  #stickman-game-shell:fullscreen .stickman-leaderboard {
    display: none !important;
  }

  #stickman-game-shell:fullscreen .stickman-game-toolbar {
    position: fixed;
    top: 12px;
    right: 12px;
    z-index: 20;
    display: block;
    margin: 0;
    pointer-events: none;
  }

  #stickman-game-shell:fullscreen .stickman-game-toolbar > div {
    display: none !important;
  }

  #stickman-game-shell:fullscreen #stickman-fullscreen-button {
    min-width: auto;
    height: 34px;
    padding: 0 12px;
    border: 1px solid rgba(255, 255, 255, 0.42);
    border-radius: 999px;
    background: rgba(15, 23, 42, 0.62);
    box-shadow: 0 10px 22px rgba(15, 23, 42, 0.24);
    font-size: 13px;
    pointer-events: auto;
    backdrop-filter: blur(8px);
  }

  #stickman-game-shell:fullscreen #stickman-game-frame {
    position: absolute;
    top: 50%;
    left: 50%;
    z-index: 1;
    width: 100vh;
    height: 100vw;
    border-radius: 0;
    background: #020617;
    transform: translate(-50%, -50%) rotate(90deg);
    transform-origin: center;
  }

  @media (max-width: 820px) {
    #stickman-game-shell:fullscreen,
    .stickman-game-shell {
      grid-template-columns: 1fr;
    }

    .stickman-game-shell:not(:fullscreen) #stickman-game-frame {
      height: clamp(480px, 70vh, 680px);
    }
  }
</style>
